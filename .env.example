# Copy this file to .env and fill in your values.

# ─── Build-time scripts (scripts/generate-prebuilt.js) ───────────────────────
# Used by Node scripts only — never bundled into the client.
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...

# Your ElevenLabs voice ID (find it in the ElevenLabs dashboard → Voices)
ELEVENLABS_VOICE_ID=...

# ─── Runtime client (Expo bundle) ────────────────────────────────────────────
# EXPO_PUBLIC_* vars get inlined into the JS bundle and are visible to anyone
# who views the page source. Only put values here that are safe to expose.

# TMDB API key — free at https://www.themoviedb.org/settings/api
# Used at runtime to fetch movie poster images for the story cards.
EXPO_PUBLIC_TMDB_API_KEY=...

# ─── Netlify Function env (production) ───────────────────────────────────────
# In production, set ANTHROPIC_API_KEY in the Netlify dashboard
# (Site settings → Environment variables) so it's available to
# netlify/functions/generate-story.mjs without leaking into the bundle.
# For local dev with `netlify dev`, the .env above is auto-loaded.
